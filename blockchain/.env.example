# ─────────────────────────────────────────────────────────
#  .env.example — copy this to .env and fill in your values
#  NEVER commit your actual .env file to GitHub!
# ─────────────────────────────────────────────────────────

# Your wallet private key (for deploying to Sepolia)
# Get this from MetaMask → Account Details → Export Private Key
PRIVATE_KEY=your_private_key_here

# Sepolia RPC URL — get a free one from https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key_here

# Etherscan API Key — for contract verification
# Get free at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ─── Filled in after deployment ───────────────────────────
# Contract address on Sepolia (filled after running deploy script)
CAMPAIGN_ESCROW_ADDRESS=0x_filled_after_deployment
POLYGON_AMOY_URL=https://polygon-amoy.g.alchemy.com/v2/9gNqu7g8aeFfq1R2SwS18
PRIVATE_KEY=53bd4afae1cbcc9e9292f462560c0423c0641c4899165b5ee3bb514c7d842c82
